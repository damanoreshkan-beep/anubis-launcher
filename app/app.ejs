<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="utf-8" http-equiv="Content-Security-Policy" content="script-src 'self' 'sha256-In6B8teKZQll5heMl9bS7CESTbGvuAt3VVV86BUQBDk='"/>
    <title><%= lang('app.title') %></title>
    <script src="./assets/js/scripts/uicore.js"></script>
    <script src="./assets/js/scripts/uibinder.js"></script>
    <link type="text/css" rel="stylesheet" href="./assets/css/site.css">
</head>
<body class="bg-surface-950 text-white antialiased">
    <%- include('frame') %>
    <div id="main">
        <%- include('welcome') %>
        <%- include('waiting') %>
        <%- include('loginOptions') %>
        <%- include('settings') %>
        <%- include('landing') %>
    </div>
    <%- include('overlay') %>

    <div id="loadingContainer">
        <video class="splash-video" autoplay muted loop playsinline poster="assets/images/site/anubis.jpg">
            <source src="assets/images/site/welcome.mp4" type="video/mp4">
        </video>
        <div class="splash-overlay"></div>
        <div class="splash-stars" id="splashStars"></div>
        <div class="splash-particles" id="splashParticles"></div>

        <div id="loadingContent" class="splash-card">
            <img class="splash-logo brand-logo animate-glow" src="assets/images/site/logo.jpg" alt="">
            <h1 class="splash-title">
                <span>Anubis</span><span class="gold-text">World</span>
            </h1>
            <div class="splash-progress">
                <div class="splash-progress-fill"></div>
            </div>
            <span class="splash-status"><%- lang('splash.loading') %></span>
            <div class="splash-dots"><span></span><span></span><span></span></div>
        </div>
    </div>
</body>
</html>
