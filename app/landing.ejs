<div id="landingContainer" style="display: none;">
    <div id="updateBanner" style="display: none;">
        <div class="updateBannerInner">
            <svg class="updateBannerIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12a9 9 0 1 1-3.5-7.13"/>
                <polyline points="21 4 21 10 15 10"/>
            </svg>
            <span class="updateBannerText">
                <strong><%- lang('landing.updateBannerTitle') %></strong>
                <em id="updateBannerVersion"></em>
            </span>
            <button id="updateBannerInstall" class="updateBannerInstall"><%- lang('landing.updateBannerInstall') %></button>
            <button id="updateBannerDismiss" class="updateBannerDismiss" aria-label="dismiss">&times;</button>
        </div>
    </div>

    <div class="lp-bg" aria-hidden="true">
        <div class="lp-grid"></div>
        <div class="lp-glow lp-glow-violet"></div>
        <div class="lp-glow lp-glow-amber"></div>
        <div class="lp-stars" id="landingStars"></div>
        <div class="lp-particles" id="landingParticles"></div>
    </div>

    <div id="upper">
        <div id="left" class="lp-nav-left">
            <div class="lp-brand glass">
                <div id="image_seal_container">
                    <img id="image_seal" src="assets/images/site/logo.jpg" alt=""/>
                    <div id="updateAvailableTooltip"><%- lang('landing.updateAvailableTooltip') %></div>
                </div>
                <span class="lp-brand-text">Anubis<span class="lp-brand-accent">World</span></span>
            </div>
        </div>

        <div id="content" class="lp-hero">
            <div class="lp-hero-text">
                <span class="lp-hero-eyebrow"><%- lang('landing.heroServerLabel') %></span>
                <h1 class="lp-hero-title">Anubis<span class="gold-text">World</span></h1>
                <p class="lp-hero-desc"><%- lang('landing.heroDesc') %></p>
                <div class="lp-hero-pills">
                    <span class="lp-pill lp-pill-status">
                        <span class="lp-dot"></span>
                        <span><%- lang('landing.heroOpenBeta') %></span>
                    </span>
                    <span class="lp-pill lp-pill-version">v<%= appVersion %></span>
                </div>
            </div>
            <div class="lp-hero-art">
                <div class="hero-portrait-wrap">
                    <video class="hero-portrait" autoplay muted loop playsinline poster="assets/images/site/anubis.jpg">
                        <source src="assets/images/site/welcome.mp4" type="video/mp4">
                    </video>
                </div>
            </div>
        </div>

        <div id="right" class="lp-nav-right">
            <div class="lp-user glass">
                <div id="user_content">
                    <span id="user_text"><%- lang('landing.usernamePlaceholder') %></span>
                    <div id="avatarContainer">
                        <button id="avatarOverlay"><%- lang('landing.usernameEditButton') %></button>
                    </div>
                </div>
            </div>
            <div class="lp-icons glass">
                <div id="mediaContent">
                    <div id="internalMedia">
                        <div class="mediaContainer" id="settingsMediaContainer">
                            <button class="mediaButton lp-icon-btn" id="settingsMediaButton" aria-label="Settings">
                                <svg id="settingsSVG" class="mediaSVG" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="3"/>
                                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                                </svg>
                                <div id="settingsTooltip"><%- lang('landing.settingsTooltip') %></div>
                            </button>
                        </div>
                    </div>
                    <div class="lp-icons-sep"></div>
                    <div id="externalMedia">
                        <div class="mediaContainer">
                            <a href="<%- lang('landing.mediaGitHubURL') %>" class="mediaURL lp-icon-btn" id="linkURL" aria-label="GitHub">
                                <svg class="mediaSVG" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                            </a>
                        </div>
                        <div class="mediaContainer">
                            <a href="<%- lang('landing.mediaDiscordURL') %>" class="mediaURL lp-icon-btn" id="discordURL" aria-label="Discord">
                                <svg class="mediaSVG" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/></svg>
                            </a>
                        </div>
                        <div class="mediaContainer">
                            <a href="<%- lang('landing.mediaXURL') %>" class="mediaURL lp-icon-btn" id="xURL" aria-label="X">
                                <svg class="mediaSVG" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                            </a>
                        </div>
                        <div class="mediaContainer">
                            <a href="<%- lang('landing.mediaYouTubeURL') %>" class="mediaURL lp-icon-btn" id="youtubeURL" aria-label="YouTube">
                                <svg class="mediaSVG" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                            </a>
                        </div>
                        <div class="mediaContainer">
                            <a href="<%- lang('landing.mediaInstagramURL') %>" class="mediaURL lp-icon-btn" id="instagramURL" aria-label="Instagram">
                                <svg class="mediaSVG" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="lower">
        <div id="left" class="lp-bottom-left">
            <div class="lp-status-stack glass">
                <div id="server_status_wrapper" class="lp-status">
                    <span class="bot_label" id="landingPlayerLabel"><%- lang('landing.serverStatus') %></span>
                    <span id="player_count"><%- lang('landing.serverStatusPlaceholder') %></span>
                </div>
                <div class="bot_divider"></div>
                <div id="mojangStatusWrapper" class="lp-status">
                    <span class="bot_label"><%- lang('landing.mojangStatus') %></span>
                    <span id="mojang_status_icon">&#8226;</span>
                    <div id="mojangStatusTooltip">
                        <div id="mojangStatusTooltipTitle"><%- lang('landing.mojangStatusTooltipTitle') %></div>
                        <div id="mojangStatusEssentialContainer"></div>
                        <div id="mojangStatusNEContainer">
                            <div class="mojangStatusNEBar"></div>
                            <div id="mojangStatusNETitle"><%- lang('landing.mojangStatusNETitle') %></div>
                            <div class="mojangStatusNEBar"></div>
                        </div>
                        <div id="mojangStatusNonEssentialContainer"></div>
                    </div>
                </div>
            </div>
        </div>

        <div id="center" class="lp-bottom-center">
            <div id="content" class="lp-news-wrap">
                <button id="newsButton" class="lp-news-btn">
                    <div id="newsButtonAlert" style="display: none;"></div>
                    <svg id="newsButtonSVG" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="18 15 12 9 6 15"/>
                    </svg>
                    <span id="newsButtonText"><%- lang('landing.newsButton') %></span>
                </button>
            </div>
        </div>

        <div id="right" class="lp-bottom-right">
            <div id="launch_content" class="lp-launch">
                <button id="launch_button" class="lp-cta-primary btn-glow">
                    <span><%- lang('landing.launchButton') %></span>
                </button>
                <button id="server_selection_button" class="lp-cta-secondary"><%- lang('landing.launchButtonPlaceholder') %></button>
            </div>
            <div id="launch_details" class="lp-launch-details">
                <div id="launch_details_left">
                    <span id="launch_progress_label">0%</span>
                </div>
                <div id="launch_details_right">
                    <progress id="launch_progress" value="0" max="100"></progress>
                    <span id="launch_details_text" class="bot_label"><%- lang('landing.launchDetails') %></span>
                </div>
            </div>
        </div>
    </div>

    <div id="newsContainer">
        <div id="newsContent" article="-1" style="display: none;">
            <div id="newsStatusContainer">
                <div id="newsStatusContent">
                    <div id="newsTitleContainer">
                        <a id="newsArticleTitle" href="#">Lorem Ipsum</a>
                    </div>
                    <div id="newsMetaContainer">
                        <div id="newsArticleDateWrapper">
                            <span id="newsArticleDate">Mar 15, 44 BC, 9:14 AM</span>
                        </div>
                        <div id="newsArticleAuthorWrapper">
                            <span id="newsArticleAuthor">by Cicero</span>
                        </div>
                        <a href="#" id="newsArticleComments">0 Comments</a>
                    </div>
                </div>
                <div id="newsNavigationContainer">
                    <button id="newsNavigateLeft">
                        <svg id="newsNavigationLeftSVG" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="15 18 9 12 15 6"/>
                        </svg>
                    </button>
                    <span id="newsNavigationStatus"><%- lang('landing.newsNavigationStatus', { currentPage: 1, totalPages: 1 }) %></span>
                    <button id="newsNavigateRight">
                        <svg id="newsNavigationRightSVG" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6"/>
                        </svg>
                    </button>
                </div>
            </div>
            <div id="newsArticleContainer">
                <div id="newsArticleContent">
                    <div id="newsArticleContentScrollable">
                        <!-- Article Content -->
                    </div>
                </div>
            </div>
        </div>
        <div id="newsErrorContainer">
            <div id="newsErrorLoading">
                <span id="nELoadSpan" class="newsErrorContent"><%- lang('landing.newsErrorLoadSpan') %></span>
            </div>
            <div id="newsErrorFailed" style="display: none;">
                <span id="nEFailedSpan" class="newsErrorContent"><%- lang('landing.newsErrorFailedSpan') %></span>
                <button id="newsErrorRetry"><%- lang('landing.newsErrorRetryButton') %></button>
            </div>
            <div id="newsErrorNone" style="display: none;">
                <span id="nENoneSpan" class="newsErrorContent"><%- lang('landing.newsErrorNoneSpan') %></span>
            </div>
        </div>
    </div>
    <script src="./assets/js/scripts/landing.js"></script>
</div>
